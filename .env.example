# --- Common ---
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=replace-me
SESSION_COOKIE_NAME=scanner_session
SESSION_DAYS=30
ALLOW_PUBLIC_SIGNUP=true
ENFORCE_HTTPS=false
SECURITY_HEADERS_ENABLED=true
AUTH_LOGIN_RATE_LIMIT_IP_MAX=10
AUTH_LOGIN_RATE_LIMIT_EMAIL_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SEC=60
AUTH_SIGNUP_RATE_LIMIT_IP_MAX=5
AUTH_SIGNUP_RATE_LIMIT_EMAIL_MAX=3
AUTH_SIGNUP_RATE_LIMIT_WINDOW_SEC=3600

# --- DB ---
POSTGRES_DB=scanner
POSTGRES_USER=scanner
POSTGRES_PASSWORD=scanner

# --- Provider ---
DATA_PROVIDER=mock
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_REQUEST_TIMEOUT_SEC=10
KIS_REQUEST_INTERVAL_MS=80
KIS_TOKEN_RETRY_COOLDOWN_SEC=65
KIS_UNIVERSE_LIMIT=120
KIS_UNIVERSE_CACHE_HOURS=24
FOREIGN_CONFIRMED_SOURCE=provider
FOREIGN_SYNC_BACKOFF_SECONDS=65
KRX_BASE_URL=http://data.krx.co.kr
KRX_REQUEST_TIMEOUT_SEC=10

# --- Scheduler ---
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_EOD_HOUR=16
SCHEDULER_EOD_MINUTE=10

# --- Proxy ---
PROXY_PORT=8080
